APP_NAME=HadiScents
APP_ENV=local
APP_KEY=base64:ISI_APP_KEY_KAMU
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# =========================
# DATABASE (MYSQL)
# =========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hadi_scents
DB_USERNAME=root
DB_PASSWORD=

# =========================
# CACHE / SESSION (FILE)
# =========================
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

SESSION_LIFETIME=120

FILESYSTEM_DISK=local

# =========================
# VITE
# =========================
VITE_APP_NAME="HadiScents"